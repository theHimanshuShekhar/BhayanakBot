{
  "name": "bhayanakbot",
  "version": "1.0.0",
  "description": "A fully custom Discord bot for the Bhayanak server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check . --write",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "youtube-dl-exec"
    ]
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@hono/node-server": "^1.19.13",
    "@sapphire/decorators": "^6.2.0",
    "@sapphire/framework": "^5.5.0",
    "@sapphire/plugin-logger": "^4.1.0",
    "@sapphire/plugin-scheduled-tasks": "^10.0.4",
    "@sapphire/plugin-subcommands": "^7.0.1",
    "@snazzah/davey": "^0.1.11",
    "bullmq": "^5.73.0",
    "discord-html-transcripts": "^3.2.0",
    "discord-player": "^7.2.0",
    "discord-player-youtubei": "3.0.0-beta.4",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "ioredis": "^5.10.1",
    "ms": "^2.1.3",
    "pg": "^8.20.0",
    "play-dl": "^1.9.7",
    "youtube-dl-exec": "^3.1.4",
    "youtube-ext": "^1.1.25",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  }
}
